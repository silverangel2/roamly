# Roamly uses the same provider accounts as ReviewIntel, but separate projects,
# product IDs, database tables, and Vercel environment variables.

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ROAMLY_APP_NAME=Roamly

# Supabase: prefer a separate Roamly Supabase project. If sharing a project,
# only use tables prefixed with roamly_.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI: reuse the existing OpenAI account/API setup.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Stripe: create one-time Roamly products/prices in the Roamly Stripe account.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
ROAMLY_STRIPE_ITINERARY_PRICE_ID=
ROAMLY_STRIPE_FEATURES_PRICE_ID=
ROAMLY_STRIPE_COMPLETE_TRIP_PRICE_ID=
# Backwards-compatible old names. Prefer the three names above.
ROAMLY_STRIPE_ITINERARY_UNLOCK_PRICE_ID=
ROAMLY_STRIPE_TRACKING_ADDON_PRICE_ID=
ROAMLY_STRIPE_TRIP_BUNDLE_PRICE_ID=

# Optional web push. In-app notifications work without these.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:junel.abellana@gmail.com
ROAMLY_NOTIFICATION_CRON_SECRET=

# Admin access for future Phase 13.
ROAMLY_ADMIN_EMAILS=
ROAMLY_SUPPORT_EMAIL=support@roamly.app
