# Roamly uses standalone production projects, database tables, and Vercel
# environment variables.

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ROAMLY_APP_NAME=Roamly

# Supabase: prefer a separate Roamly Supabase project. If sharing a project,
# only use tables prefixed with roamly_.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI: reuse the existing OpenAI account/API setup.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Stripe: create one-time Roamly products/prices in the Roamly Stripe account.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
ROAMLY_STRIPE_ITINERARY_PRICE_ID=
ROAMLY_STRIPE_FEATURES_PRICE_ID=
ROAMLY_STRIPE_COMPLETE_TRIP_PRICE_ID=
# Backwards-compatible old names. Prefer the three names above.
ROAMLY_STRIPE_ITINERARY_UNLOCK_PRICE_ID=
ROAMLY_STRIPE_TRACKING_ADDON_PRICE_ID=
ROAMLY_STRIPE_TRIP_BUNDLE_PRICE_ID=

# Optional web push. In-app notifications work without these.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:junel.abellana@gmail.com
ROAMLY_NOTIFICATION_CRON_SECRET=

# Optional affiliate wiring. Keep disabled until a provider account is approved.
NEXT_PUBLIC_TRAVELPAYOUTS_DRIVE_ENABLED=false
NEXT_PUBLIC_AIRALO_IMPACT_ENABLED=false
ROAMLY_AFFILIATES_ENABLED=false
ROAMLY_ESIM_PROVIDER=airalo
ROAMLY_ESIM_ENABLED=true
ROAMLY_ESIM_REFERRAL_URL=
ROAMLY_ESIM_AFFILIATE_ID=
ROAMLY_HOTEL_AFFILIATE_PROVIDER=stay22
ROAMLY_HOTEL_AFFILIATE_ID=
ROAMLY_STAY22_REFERRAL_URL=https://hub.stay22.com/referral/roamly/travel
ROAMLY_STAY22_PARTNER_ID=
ROAMLY_EXPEDIA_AFFILIATE_ID=
ROAMLY_BOOKING_AFFILIATE_ID=
ROAMLY_FLIGHT_AFFILIATE_PROVIDER=
ROAMLY_FLIGHT_AFFILIATE_ID=
ROAMLY_TRAVELPAYOUTS_MARKER=
ROAMLY_AMADEUS_CLIENT_ID=
ROAMLY_AMADEUS_CLIENT_SECRET=
ROAMLY_ATTRACTIONS_AFFILIATE_PROVIDER=klook
ROAMLY_ATTRACTIONS_AFFILIATE_ID=
ROAMLY_GETYOURGUIDE_PARTNER_ID=
ROAMLY_VIATOR_PARTNER_ID=
ROAMLY_KLOOK_PARTNER_ID=127045
ROAMLY_KLOOK_REFERRAL_URL=https://affiliate.klook.com/redirect?aid=127045&aff_adid=1336919&k_site=https%3A%2F%2Fwww.klook.com%2F
ROAMLY_TIQETS_PARTNER_ID=

# Support email and app delivery.
ROAMLY_SUPPORT_EMAIL=support@roamlyhq.com
ROAMLY_FROM_EMAIL=support@roamlyhq.com
ROAMLY_EMAIL_PROVIDER=
RESEND_API_KEY=

# Admin/tester access.
ROAMLY_ADMIN_EMAILS=support@roamlyhq.com
ROAMLY_TESTER_EMAILS=

# Facebook automation and Meta posting. Keep live publishing disabled until
# Page validation, one controlled image post, and one controlled Reel succeed.
ROAMLY_SOCIAL_CRON_SECRET=
ROAMLY_SOCIAL_AUTOPOST_ENABLED=false
ROAMLY_SOCIAL_REQUIRE_APPROVAL=false
ROAMLY_SOCIAL_POSTS_PER_DAY=2
ROAMLY_SOCIAL_REELS_PER_WEEK=3
ROAMLY_SOCIAL_MIN_QUEUE_SIZE=30
ROAMLY_SOCIAL_MAX_QUEUE_SIZE=100
ROAMLY_SOCIAL_MAX_DAILY_POSTS=3
ROAMLY_TIME_ZONE=America/Moncton
ROAMLY_META_GRAPH_VERSION=v23.0
ROAMLY_META_PAGE_ID=
ROAMLY_META_ACCESS_TOKEN=
ROAMLY_INSTAGRAM_BUSINESS_ACCOUNT_ID=
ROAMLY_SOCIAL_FACEBOOK_ENABLED=false
ROAMLY_SOCIAL_INSTAGRAM_ENABLED=false
